# ── AI ───────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Database ─────────────────────────────────────────────────
# PostgreSQL (production)
DATABASE_URL=postgresql+psycopg2://clipsgold:password@localhost:5432/clipsgold
# SQLite (local dev, no Postgres needed)
# DATABASE_URL=sqlite:///./clipsgold_dev.db

# ── Auth (JWT) ────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_generate_a_random_64_char_hex_string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Redis / Celery ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── S3-compatible storage ─────────────────────────────────────
# Leave S3_BUCKET empty to use local disk (dev mode)
S3_BUCKET=
S3_REGION=us-east-1
# For Cloudflare R2 or MinIO, set a custom endpoint:
# S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_PRESIGN_EXPIRY=3600

# ── Observability ─────────────────────────────────────────────
# Leave empty to disable Sentry
SENTRY_DSN=
ENVIRONMENT=development
APP_VERSION=1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Rate limiting ─────────────────────────────────────────────
# Set to 1 if running behind a trusted reverse proxy (nginx/Cloudflare)
TRUST_PROXY=0

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Usage cost constants (USD) ────────────────────────────────
COST_WHISPER_PER_MIN=0.006
COST_GPT4O_PER_1K=0.005
COST_RENDER_PER_SEC=0.0001
COST_STORAGE_PER_GB=0.023

# ── YouTube import ────────────────────────────────────────────
# Optional: cookies for age-restricted / throttled downloads.
# Option A: path to a Netscape-format cookie file
# YOUTUBE_COOKIES_FILE=./youtube_cookies.txt
# Option B: raw Cookie header value
# YOUTUBE_COOKIES="VISITOR_INFO1_LIVE=...; PREF=...; ..."

# ── Autonomous Factory ────────────────────────────────────────
# Enable headless mode (factory runs autonomously without manual commands)
AUTONOMOUS_MODE=False

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# YouTube auto-uploader (requires OAuth2 setup)
# Download credentials from: https://console.cloud.google.com/apis/credentials
# Save as: youtube_credentials.json
YOUTUBE_AUTO_UPLOAD=False
YOUTUBE_DEFAULT_PRIVACY=private  # private, unlisted, public
