# ── AI ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...         # optional — used for Whisper transcription

# ── Database ──────────────────────────────────────────────────
# Docker Compose wires this automatically; override only if using external DB
POSTGRES_PASSWORD=clipsgold
DATABASE_URL=postgresql+psycopg2://clipsgold:clipsgold@postgres:5432/clipsgold

# ── Auth (JWT) ────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_generate_a_random_64_char_hex_string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── S3-compatible storage ─────────────────────────────────────
# Leave S3_BUCKET empty to use local disk (dev mode)
S3_BUCKET=
S3_REGION=us-east-1
# For Cloudflare R2 or MinIO:
# S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_PRESIGN_EXPIRY=3600

# ── Observability ─────────────────────────────────────────────
SENTRY_DSN=
ENVIRONMENT=production
APP_VERSION=1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=https://clipsgold.ru,https://www.clipsgold.ru
TRUST_PROXY=1

# ── Autonomous Factory ────────────────────────────────────────
AUTONOMOUS_MODE=True
DOWNLOADS_DIR=downloads
PROXIES=

# ── Telegram notifications ────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── YouTube ───────────────────────────────────────────────────
YOUTUBE_AUTO_UPLOAD=False
YOUTUBE_DEFAULT_PRIVACY=private
# YOUTUBE_COOKIES_FILE=./youtube_cookies.txt
